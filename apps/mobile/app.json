{
  "expo": {
    "name": "Everglow",
    "slug": "everglow",
    "version": "1.0.0",
    "scheme": "everglow",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.everglow.app",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Everglow uses Bluetooth to connect to your bracelet.",
        "UIBackgroundModes": [
          "remote-notification",
          "bluetooth-central"
        ]
      }
    },
    "android": {
      "package": "com.everglow.app",
      "adaptiveIcon": {
        "backgroundColor": "#1A1A1A",
        "foregroundImage": "./assets/android-icon-foreground.png"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": [
            "peripheral",
            "central"
          ],
          "bluetoothAlwaysPermission": "Allow Everglow to connect to your bracelet."
        }
      ],
      "expo-secure-store",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
