# Root-level reference only — each app reads its own .env file from its directory.
# Copy the relevant section into apps/mobile/.env and apps/api/.env.

# apps/mobile/.env (Expo — EXPO_PUBLIC_ prefix required for client-side access)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_API_URL=http://localhost:3000

# apps/api/.env (Next.js)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
ABLY_API_KEY=your-ably-api-key-here

# APNs silent push (background wake for the beat relay) — see APNS_SETUP.md.
# Leave as PLACEHOLDER to run on the Ably-only path; no code changes to enable.
APNS_KEY_ID=PLACEHOLDER
APNS_TEAM_ID=PLACEHOLDER
APNS_PRIVATE_KEY=PLACEHOLDER
APNS_BUNDLE_ID=com.everglow.app
APNS_ENVIRONMENT=sandbox
