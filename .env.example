# Root-level reference only — each app reads its own .env file from its directory.
# Copy the relevant section into apps/mobile/.env and apps/api/.env.

# apps/mobile/.env (Expo — EXPO_PUBLIC_ prefix required for client-side access)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_API_URL=http://localhost:3000

# apps/api/.env (Next.js)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
